{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.slim"
  },
  "deploy": {
    "startCommand": "alembic -c alembic.ini upgrade slim@head && uvicorn app.main_slim:app --host 0.0.0.0 --port ${PORT:-8000}",
    "healthcheckPath": "/api/v1/proctoring/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
