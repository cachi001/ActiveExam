# Dockerfile.slim — modulo slim de proctoring para Railway
#
# Build desde la RAIZ del repo (para acceder a frontend/public/mediapipe/):
#   docker build -f Dockerfile.slim .
#
# Railway inyecta automaticamente: DATABASE_URL, FRONTEND_ORIGIN, PORT
# Variables de entorno requeridas:
#   DATABASE_URL       Requerida. Ej: postgresql+asyncpg://user:pass@host:5432/db
#   FRONTEND_ORIGIN    Requerida. Ej: https://activeexam.vercel.app
#   PORT               Auto (Railway). Default: 8000
#   MEDIAPIPE_MODEL_DIR  Opcional. Default: /app/models
#
# El CMD corre primero la migracion slim (branch independiente, sin TimescaleDB)
# y luego levanta uvicorn en $PORT.

FROM python:3.12-slim

# Directorio de trabajo dentro del contenedor
WORKDIR /app

# mediapipe (y su dependencia opencv-contrib-python) requieren libGL y glib en
# runtime. En Debian bookworm (base de python:3.12-slim) el paquete es 'libgl1'
# — NO 'libgl1-mesa-glx', que fue removido en bookworm. Sin estas libs,
# "import mediapipe" falla con "libGL.so.1: cannot open shared object file" y la
# re-inferencia degrada a 'no_evaluado' (justo el motor real que queremos probar).
RUN apt-get update \
    && apt-get install -y --no-install-recommends libgl1 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Instalar dependencias Python (incluye mediapipe para re-inferencia server-side, D8)
COPY backend/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copiar el codigo del backend
COPY backend/ .

# Reusar el MISMO modelo .task que el cliente (D8, D8b):
# - garantiza comparacion apples-to-apples cliente-vs-servidor
# - el .task ya esta versionado en el repo (frontend/public/mediapipe/)
# - viaja dentro de la imagen (sin descarga en runtime)
# PRODUCCION: si el modelo cambia de version, actualizar tambien en el cliente
COPY frontend/public/mediapipe/face_detector_short_range.task /app/models/face_detector_short_range.task

# Variables de entorno del contenedor
ENV PYTHONPATH=/app
ENV MEDIAPIPE_MODEL_DIR=/app/models
# Sin buffering: que los logs de Alembic/uvicorn salgan en vivo (si no, un crash
# al arrancar no imprime nada y solo se ve "Starting Container"). Critico para debug.
ENV PYTHONUNBUFFERED=1
# lock_timeout: si la migracion no consigue el lock de DDL en 15s, FALLA con error
# claro en vez de colgarse hasta el timeout del healthcheck (caso tipico: dos
# contenedores migrando a la vez en un rolling deploy). statement_timeout corta
# cualquier sentencia >120s. Solo afecta a psycopg2 (Alembic); asyncpg (la app)
# ignora PGOPTIONS, asi que el runtime no queda con timeouts agresivos.
ENV PGOPTIONS="-c lock_timeout=15000 -c statement_timeout=120000"

# CMD: primero migrar (branch slim, sin TimescaleDB), luego servir.
# Marcadores [1/2]/[2/2] para ver EXACTAMENTE donde se queda si algo falla:
# si ves [1/2] pero no [2/2], el problema es la migracion; si ves [2/2] pero
# no "Uvicorn running", el problema es el arranque del server.
CMD echo ">>> [1/2] migrando DB (alembic slim@head)..." && \
    alembic -c alembic.ini upgrade slim@head && \
    echo ">>> [2/2] migracion OK -> levantando uvicorn en ${PORT:-8000}" && \
    uvicorn app.main_slim:app --host 0.0.0.0 --port ${PORT:-8000}
