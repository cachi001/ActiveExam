# =============================================================================
# .env.example ŌĆö contrato de variables de entorno (twelve-factor, DD-11)
# =============================================================================
# Copia este archivo a `.env` para el stack LOCAL. NUNCA pongas secretos reales
# en `.env` ni los commitees.
#
# GESTION DE SECRETOS (DD-5 / `08` Gestion de secretos):
#   En PRODUCCION los valores marcados [SECRETO] se inyectan via HashiCorp Vault
#   en un tmpfs efimero en runtime ŌĆö NUNCA se hornean en la imagen Docker ni se
#   versionan. Los valores de abajo son PLACEHOLDERS DE DESARROLLO LOCAL.
# =============================================================================

# --- App / runtime ---
ENVIRONMENT=local
APP_NAME=proctoring-api
API_V1_PREFIX=/api/v1

# --- Base de datos PostgreSQL/TimescaleDB --- [SECRETO en prod -> Vault/tmpfs]
DATABASE_URL=postgresql+asyncpg://proctoring:dev-only-change-me@postgres:5432/proctoring
POSTGRES_USER=proctoring
POSTGRES_PASSWORD=dev-only-change-me
POSTGRES_DB=proctoring

# --- Object storage MinIO/S3 ---
STORAGE_ENDPOINT=http://minio:9000
STORAGE_BUCKET_EVIDENCE=evidence
STORAGE_ACCESS_KEY=dev-minio-access            # [SECRETO en prod -> Vault/tmpfs]
STORAGE_SECRET_KEY=dev-minio-secret-change-me  # [SECRETO en prod -> Vault/tmpfs]
MINIO_ROOT_USER=dev-minio-access
MINIO_ROOT_PASSWORD=dev-minio-secret-change-me

# --- Identidad (Keycloak) ŌĆö auth REAL es C-06; aqui solo corre el contenedor ---
KEYCLOAK_ISSUER=http://localhost:8080/realms/proctoring  # iss del token (hostname expuesto al browser; KC_HOSTNAME_URL lo fija)
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/proctoring/protocol/openid-connect/certs  # backchannel Docker interno (el backend no pasa por el browser)
JWT_AUDIENCE=proctoring-api
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=dev-only-change-me     # [SECRETO en prod -> Vault/tmpfs]

# --- Gestion de secretos (Vault) --- [SECRETO -> inyeccion de arranque]
VAULT_ADDR=
VAULT_TOKEN=

# --- Observabilidad (OpenTelemetry / DD-12) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=proctoring-api

# --- Mensajeria (pieza decidida por la PoC C-03; default A4 = postgres) ---
# NO levantar redis/rabbitmq por defecto (DD-19). Cambiar SOLO si C-03 lo exige.
MESSAGING_BACKEND=postgres

# --- Auth provider propio (C-55) Ś proveedor JWT propio como alternativa a Keycloak ---
# AUTH_PROVIDER: 'jwt' = formulario login + JWT propio (default, MVP self-hosted)
#                'keycloak' = flujo OIDC PKCE (C-06, requiere Keycloak corriendo)
#                'demo' = selector de roles sin red (Vercel demo)
AUTH_PROVIDER=jwt

# Secreto HS256 para firmar los JWT propios. [SECRETO en prod -> Vault/tmpfs]
# Minimo 32 chars aleatorios. Ejemplo: openssl rand -hex 32
JWT_OWN_SECRET=CHANGE_ME_use_openssl_rand_hex_32_at_least  # [SECRETO]
JWT_OWN_ISSUER=activeexam-auth
REFRESH_TOKEN_TTL_SECONDS=604800  # 7 dias (default)

# Contrase±as de usuarios seed (SOLO entorno local / staging). [SECRETO]
# El script backend/scripts/seed_users.py las lee al correr.
SEED_ESTUDIANTE_PASSWORD=CHANGE_ME_min8chars
SEED_PROCTOR_PASSWORD=CHANGE_ME_min8chars
SEED_ADMIN_PASSWORD=CHANGE_ME_min8chars

# Frontend: proveedor de auth activo (debe coincidir con AUTH_PROVIDER del backend)
# VITE_AUTH_PROVIDER=jwt   # (default en .env local)
