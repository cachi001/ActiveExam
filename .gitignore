# Entorno y secretos — NUNCA versionar (DD-5)
.env
*.env.local

# Certificados / claves privadas TLS (local) — solo el README se versiona
infra/nginx/tls/*.key
infra/nginx/tls/*.crt
infra/nginx/tls/*.pem

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
*.egg-info/

# Node / frontend
node_modules/
dist/
.vite/

# MediaPipe models y WASM (~42 MB) — COMMITEADOS al repo para que Vercel los sirva
# como assets estáticos (self-hosted, sin CDN en runtime). Regenerables con
# scripts/download-mediapipe-models.sh si hiciera falta.

# Datos de contenedores
postgres_data/
minio_data/

# Estado de herramientas de scaffolding local — no es parte del proyecto
*-state.json
.claude/

# Playwright MCP screenshots / dumps de review
.playwright-mcp/
*.stackdump
